{
  "name": "dishcovered",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:check": "tsx scripts/deploy-check.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --conditions=react-server --import tsx scripts/seed.ts",
    "backfill:images": "node --conditions=react-server --import tsx scripts/backfill-images.ts",
    "backfill:source-keys": "node --conditions=react-server --import tsx scripts/backfill-source-keys.ts",
    "migrate:images": "node --conditions=react-server --import tsx scripts/migrate-images-to-storage.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@electric-sql/pglite": "^0.5.1",
    "@mozilla/readability": "^0.6.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convert": "^7.0.0",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^28.1.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "parse-ingredient": "^2.2.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "youtube-caption-extractor": "^1.10.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
