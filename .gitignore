# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-*/
/out/
/.next-dev.*.log

# production
/build

# misc
.DS_Store
*.pem

# local embedded database (PGlite)
/.pglite

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel
.vercel-cli-data
.vercel-cli-local

# local CLI/package caches
.npm-cache

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Logo source (public/ holds the derived, optimized assets)
/DISHCOVERED.png
