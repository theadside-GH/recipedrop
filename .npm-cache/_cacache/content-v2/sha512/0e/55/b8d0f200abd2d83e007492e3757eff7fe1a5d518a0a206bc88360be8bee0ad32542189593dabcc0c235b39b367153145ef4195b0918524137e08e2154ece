.1-beta.1":"2026-01-21T02:40:39.981Z","4.1.0-beta.2":"2026-02-02T18:37:03.966Z","4.1.0":"2026-04-07T23:54:41.745Z","5.0.0-beta.0":"2026-04-08T00:39:01.661Z","5.0.0-beta.1":"2026-04-16T22:35:48.397Z","4.1.1":"2026-04-16T22:43:10.653Z","5.0.0-beta.2":"2026-05-28T18:21:09.226Z","4.1.2":"2026-06-11T00:26:36.408Z"},"bugs":{"url":"https://github.com/vercel/workflow/issues"},"license":"Apache-2.0","homepage":"https://github.com/vercel/workflow#readme","repository":{"type":"git","url":"git+https://github.com/vercel/workflow.git","directory":"packages/serde"},"description":"Serialization symbols for custom class serialization in Workflow SDK","maintainers":[],"readme":"# @workflow/serde\n\nSerialization symbols for custom class serialization in Workflow SDK.\n\n## Usage\n\n<!-- @skip-typecheck - self-referential import -->\n\n```ts\nimport { WORKFLOW_SERIALIZE, WORKFLOW_DESERIALIZE } from '@workflow/serde';\n\nclass MyClass {\n  constructor(public value: string) {}\n\n  static [WORKFLOW_SERIALIZE](instance: MyClass) {\n    return { value: instance.value };\n  }\n\n  static [WORKFLOW_DESERIALIZE](data: { value: string }) {\n    return new MyClass(data.value);\n  }\n}\n```\n\n## License\n\nApache-2.0\n","readmeFilename":"README.md"}